# Copy this file to .env and fill in your API keys.
#
# GOOGLE_API_KEY    — required for all Gemini models (runner.py).
# OPENAI_API_KEY    — required for OpenAI models via LiteLlm (runner.py)
#                     and for the judge (judge.py, default: gpt-5-mini).
#
# For other providers (Anthropic, etc.), add the corresponding key that
# LiteLlm expects (e.g. ANTHROPIC_API_KEY). See: https://docs.litellm.ai/docs/providers

GOOGLE_API_KEY=your_google_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
